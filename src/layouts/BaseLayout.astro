---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  activeNav?: 'about' | 'portfolio' | 'paths' | 'branding' | 'process' | 'sns' | 'faq' | null;
  /** common.js를 페이지에서 사용하지 않는 경우 false */
  loadCommonJs?: boolean;
  /** 페이지 고유 JS 파일 (예: 'portfolio.js'). 없으면 미로드. */
  pageJs?: string;
  /** 홈페이지(루트 /)에서만 true. Google site name 추출용 WebSite 스키마를 출력. */
  isHomepage?: boolean;
}

const {
  title,
  description,
  keywords,
  canonical,
  ogTitle,
  ogDescription,
  ogImage,
  ogType,
  activeNav,
  loadCommonJs = true,
  pageJs,
  isHomepage = false,
} = Astro.props;

const SITE_URL = 'https://convill-homepage-ver2.vercel.app';

// Google 검색 결과에 "Vercel" 대신 사이트 이름을 띄우려면 홈페이지에 WebSite 스키마가 필요.
// publisher를 LocalBusiness(#organization)와 @id로 묶어 동일 주체로 인식되게 함.
const websiteSchema = isHomepage ? {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_URL}/#website`,
  name: '컨빌디자인',
  alternateName: 'CONVIL Church Studio',
  url: `${SITE_URL}/`,
  inLanguage: 'ko',
  publisher: { '@id': `${SITE_URL}/#organization` },
} : null;
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <SEOHead
    title={title}
    description={description}
    keywords={keywords}
    canonical={canonical}
    ogTitle={ogTitle}
    ogDescription={ogDescription}
    ogImage={ogImage}
    ogType={ogType}
  />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />
  {websiteSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  )}
  {loadCommonJs && <script src="/js/common.js" is:inline defer></script>}
  {pageJs && <script src={`/js/${pageJs}`} is:inline defer></script>}
</head>
<body>
  <Header activeNav={activeNav} />
  <MobileMenu />

  <slot />

  <Footer />
</body>
</html>
