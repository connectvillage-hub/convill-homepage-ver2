---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'portfolio'>;
}

const { entry } = Astro.props;
const data = entry.data;

const SITE_URL = 'https://convill-homepage-ver2.vercel.app';
const canonicalPath = `/portfolio_detail${data.id}.html`;
const ogImage = data.ogImage ?? `${SITE_URL}${data.listImage}`;

// Related projects — relatedIds로 다른 entries 조회
const allEntries = await getCollection('portfolio');
const relatedEntries = data.relatedIds
  .map(id => allEntries.find(e => e.data.id === id))
  .filter((e): e is CollectionEntry<'portfolio'> => Boolean(e));
---
<BaseLayout
  title={data.ogTitle ?? `${data.church} ${data.projectType} — 컨빌디자인 포트폴리오`}
  description={data.description}
  keywords={data.keywords}
  canonical={canonicalPath}
  ogTitle={data.ogTitle}
  ogDescription={data.ogDescription}
  ogImage={ogImage}
  ogType="article"
  activeNav="portfolio"
  pageJs="portfolio.js"
>
  <div id="page-pf-detail" class={`case${data.id}`}>

    <!-- BREADCRUMB -->
    <div class="breadcrumb-bar">
      <div class="container">
        <div class="breadcrumb">
          <a href="/index.html" class="nav-link">Home</a>
          <span class="sep">/</span>
          <a href="/portfolio_list.html" class="nav-link">Portfolio</a>
          <span class="sep">/</span>
          <span class="current" style="color:var(--ink)">{data.breadcrumb}</span>
        </div>
      </div>
    </div>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-img">
        <div class="hero-overlay">
          <h1 set:html={data.title} />
          <div class="hero-meta">
            <span>{data.church}</span><span>· {data.scaleInfo}</span><span>· {data.period}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- INFO BAR -->
    <section class="info-bar">
      <div class="container">
        <dl class="info-grid">
          <div class="info-cell"><dt>CHURCH</dt><dd>{data.church}</dd></div>
          <div class="info-cell"><dt>LOCATION</dt><dd>{data.location}</dd></div>
          <div class="info-cell"><dt>TYPE</dt><dd>{data.projectType}</dd></div>
          <div class="info-cell"><dt>SCALE</dt><dd set:html={data.scale} /></div>
          <div class="info-cell"><dt>PERIOD</dt><dd>{data.period}</dd></div>
        </dl>
      </div>
    </section>

    <!-- INTRO -->
    <section class="intro">
      <div class="container-narrow">
        <div class="intro-eye">— PROJECT NOTE</div>
        <p>{data.intro}</p>
      </div>
    </section>

    {data.beforeAfters.length > 0 && (
      <section class="ba-section">
        <div class="container-narrow">
          <div class="intro-eye">— BEFORE &amp; AFTER</div>
          <h2 class="ba-title">시공 전후 비교</h2>
          <p class="ba-desc">슬라이더를 좌우로 드래그하여 공사 전과 후를 비교해보세요.</p>
          {data.beforeAfters.map(pair => (
            <div class="ba-slider">
              <img class="ba-after" src={pair.after} alt={pair.afterAlt} />
              <img class="ba-before" src={pair.before} alt={pair.beforeAlt} />
              <div class="ba-divider">
                <div class="ba-handle">
                  <svg viewBox="0 0 10 16"><polygon points="10,0 0,8 10,16"/></svg>
                  <svg viewBox="0 0 10 16"><polygon points="0,0 10,8 0,16"/></svg>
                </div>
              </div>
              <span class="ba-tag ba-tag-before">BEFORE</span>
              <span class="ba-tag ba-tag-after">AFTER</span>
            </div>
          ))}
        </div>
      </section>
    )}

    {data.gallery.length > 0 && (
      <section class="gallery">
        <div class="container">
          {data.gallery.map(pair => (
            <div class="g-pair">
              {pair.images.map(img => (
                <figure class={`g-item ${img.isFull ? 'full ' : ''}reveal`}>
                  <div class="g-img" style={`background-image:url('${img.src}')`}></div>
                  {img.caption && <figcaption>{img.caption}</figcaption>}
                </figure>
              ))}
            </div>
          ))}
        </div>
      </section>
    )}

    {data.testimony && (
      <section class="testimony">
        <div class="testimony-inner">
          <div class="test-eye">— PASTOR'S WORDS</div>
          <blockquote>{data.testimony.quote}</blockquote>
          <div class="test-author">
            <div class="test-info">
              <div class="test-role">{data.testimony.author}</div>
            </div>
          </div>
          {data.testimony.youtube && (
            <div style="margin-top: 50px;">
              <article class="yt-card" data-yt-item onclick={`window.open('${data.testimony.youtube.url}', '_blank')`}>
                <div class="yt-info">
                  <h3 style="color: #fff;">{data.testimony.youtube.title}</h3>
                </div>
                <div class="yt-thumb">
                  <div class="ph" style={`background-image:url('${data.testimony.youtube.thumbnail}')`}></div>
                  <span class="yt-duration">{data.testimony.youtube.duration}</span>
                </div>
              </article>
            </div>
          )}
        </div>
      </section>
    )}

    {relatedEntries.length > 0 && (
      <section class="related">
        <div class="container">
          <div class="related-head">
            <span class="eye">— RELATED PROJECTS</span>
            <h2>이 프로젝트와 함께 보면 좋은 작업들</h2>
          </div>
          <div class="rel-grid">
            {relatedEntries.map(rel => (
              <a href={`/portfolio_detail${rel.data.id}.html`} class="rel-card nav-link">
                <div class="ph" style={`background-image:url('${rel.data.listImage}')`}></div>
                <div class="rel-overlay">
                  <h3>{rel.data.listTitle}</h3>
                  <span>{rel.data.listSubtitle}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="cta-strip">
      <div class="container">
        <span class="eye">— LET'S WORK TOGETHER</span>
        <h2>우리 교회도, <span class="ws">새로워질 수</span> 있습니다.</h2>
        <p>우리 교회에 가장 잘 어울리는 공간은 어떻게 시작해야 할까요?<br />혼자 고민하지 마세요. 저희가 도와드리겠습니다.</p>
        <a href="https://zrr.kr/BEsbko" target="_blank" rel="noopener" class="nav-link">무료 상담 신청하기 →</a>
      </div>
    </section>

  </div><!-- /page-pf-detail -->
</BaseLayout>
