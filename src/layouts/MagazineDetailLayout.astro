---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { marked } from 'marked';

interface Props {
  entry: CollectionEntry<'magazine'>;
}

const { entry } = Astro.props;
const data = entry.data;

// 인라인 마크다운 → HTML (굵게/기울임/링크/<span> 등 허용, <p>는 안 감쌈)
const renderInline = (s: string | undefined | null) => {
  if (!s) return '';
  const withBr = String(s).replace(/\r\n|\r|\n/g, '<br>');
  return marked.parseInline(withBr, { breaks: false }) as string;
};

const SITE_URL = 'https://convill-homepage-ver2.vercel.app';
const canonicalPath = `/${entry.slug}`;
const canonicalUrl = `${SITE_URL}${canonicalPath}`;
const ogImage = data.seo.ogImage ?? data.heroImage;

const stripBr = (s: string) => s.replace(/<br\s*\/?>/gi, ' ').replace(/\s+/g, ' ').trim();
// 엔터(\n)를 <br>로 변환 — 사용자가 admin에서 엔터만 쳐도 줄바꿈되게
const nl2br = (s: string | undefined | null) => (s ?? '').replace(/\r\n|\r|\n/g, '<br>');
const plainTitle = stripBr(data.title);
const plainDek = stripBr(data.dek);

const formattedDate = data.publishDate.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).replace(/\.\s*$/, '').replace(/\.\s*/g, '.');

const isoPublishDate = data.publishDate.toISOString().split('T')[0];

// sections 안의 모든 이미지를 모음 (Schema.org image array, SEO 강화용)
const sections = data.sections ?? [];
const hasSections = sections.length > 0;

const sectionImages: string[] = [];
for (const s of sections) {
  if (s.type === 'figure' || s.type === 'text-image') sectionImages.push(s.src);
  else if (s.type === 'ba') { sectionImages.push(s.afterSrc); sectionImages.push(s.beforeSrc); }
}
const toAbsUrl = (src: string) => (src.startsWith('http') ? src : `${SITE_URL}${src}`);
const allImageUrls = [data.heroImage, ...sectionImages].map(toAbsUrl);

// Article Schema (JSON-LD) — for Google + AI
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: plainTitle,
  description: data.seo.description,
  image: allImageUrls,
  datePublished: isoPublishDate,
  dateModified: isoPublishDate,
  author: {
    '@type': 'Organization',
    name: '컨빌디자인',
    url: SITE_URL + '/',
  },
  publisher: {
    '@type': 'Organization',
    name: '컨빌디자인',
    logo: {
      '@type': 'ImageObject',
      url: `${SITE_URL}/images/main.png`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
};

// BreadcrumbList Schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Magazine', item: `${SITE_URL}/magazine.html` },
    { '@type': 'ListItem', position: 3, name: plainTitle, item: canonicalUrl },
  ],
};
---
<BaseLayout
  title={`${plainTitle} — 컨빌디자인 매거진`}
  description={data.seo.description}
  keywords={data.seo.keywords}
  canonical={canonicalPath}
  ogTitle={plainTitle}
  ogDescription={data.seo.description}
  ogImage={ogImage}
  ogType="article"
  activeNav="sns"
  pageJs="portfolio.js"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- BREADCRUMB -->
  <div class="breadcrumb-bar">
    <div class="container">
      <div class="breadcrumb">
        <a href="/index.html" class="nav-link">Home</a>
        <span class="sep">/</span>
        <a href="/magazine.html" class="nav-link">Magazine</a>
        <span class="sep">/</span>
        <span class="current" style="color:var(--ink)">{plainTitle}</span>
      </div>
    </div>
  </div>

  <article>
    <header class="mag-article-head">
      <div class="mag-eyebrow">
        {data.category} <span>·</span> {formattedDate} <span>·</span> {data.readingTime}
      </div>
      <h1 set:html={nl2br(data.title)} />
      <p class="mag-dek" set:html={nl2br(data.dek)} />
    </header>

    <div class="mag-hero-image">
      <img src={data.heroImage} alt={data.heroImageAlt} />
    </div>

    <div class="mag-body">
      <p class="lead" set:html={nl2br(data.lead)} />

      {hasSections ? sections.map(section => {
        if (section.type === 'heading') {
          return section.level === 'h3'
            ? <h3 set:html={nl2br(section.text)} />
            : <h2 set:html={nl2br(section.text)} />;
        }
        if (section.type === 'paragraph') {
          return <p set:html={renderInline(section.text)} />;
        }
        if (section.type === 'list') {
          return section.style === 'ol'
            ? <ol>{section.items.map(item => <li set:html={renderInline(item)} />)}</ol>
            : <ul>{section.items.map(item => <li set:html={renderInline(item)} />)}</ul>;
        }
        if (section.type === 'figure') {
          return (
            <figure>
              <img src={section.src} alt={section.alt} loading="lazy" />
              {section.caption && <figcaption set:html={nl2br(section.caption)} />}
            </figure>
          );
        }
        if (section.type === 'ba') {
          return (
            <div class="ba-slider">
              <img class="ba-after" src={section.afterSrc} alt={section.afterAlt} />
              <img class="ba-before" src={section.beforeSrc} alt={section.beforeAlt} />
              <div class="ba-divider">
                <div class="ba-handle">
                  <svg viewBox="0 0 10 16"><polygon points="10,0 0,8 10,16" /></svg>
                  <svg viewBox="0 0 10 16"><polygon points="0,0 10,8 0,16" /></svg>
                </div>
              </div>
              <span class="ba-tag ba-tag-before">BEFORE</span>
              <span class="ba-tag ba-tag-after">AFTER</span>
            </div>
          );
        }
        if (section.type === 'quote') {
          return <blockquote set:html={renderInline(section.text)} />;
        }
        if (section.type === 'link') {
          return (
            <p>
              <a href={section.href} title={section.title}>{section.text}</a>
            </p>
          );
        }
        if (section.type === 'text-image') {
          return (
            <Fragment>
              <p set:html={renderInline(section.text)} />
              <figure>
                <img src={section.src} alt={section.alt} loading="lazy" />
                {section.caption && <figcaption set:html={nl2br(section.caption)} />}
              </figure>
            </Fragment>
          );
        }
        if (section.type === 'divider') {
          if (section.style === 'space') {
            return <div style="height: 32px" />;
          }
          const borderStyle = section.style === 'dashed' ? 'dashed' : (section.style === 'dotted' ? 'dotted' : 'solid');
          return <hr style={`border: none; border-top: 1px ${borderStyle} #ddd; margin: 32px 0;`} />;
        }
        if (section.type === 'gallery') {
          const cols = section.cols ?? 2;
          return (
            <div style={`display: grid; grid-template-columns: repeat(${cols}, 1fr); gap: 12px; margin: 24px 0;`}>
              {section.images.map(img => (
                <figure style="margin: 0;">
                  <img src={img.src} alt={img.alt} loading="lazy" style="width: 100%; display: block;" />
                  {img.caption && <figcaption style="font-size: 13px; color: #888; text-align: center; margin-top: 6px;" set:html={nl2br(img.caption)} />}
                </figure>
              ))}
            </div>
          );
        }
        return null;
      }) : <slot />}
    </div>

    <div class="mag-tags">
      <div class="mag-tags-row">
        {data.tags.map(tag => <span class="mag-tag">{tag}</span>)}
      </div>
    </div>

    <div class="mag-back">
      <a href="/magazine.html">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        매거진 전체 보기
      </a>
    </div>
  </article>

  <section class="cta-strip">
    <div class="container">
      <span class="eye">— LET'S WORK TOGETHER</span>
      <h2>우리 교회도, <span class="ws">새로워질 수</span> 있습니다.</h2>
      <p>우리 교회에 가장 잘 어울리는 공간은 어떻게 시작해야 할까요?<br />혼자 고민하지 마세요. 저희가 도와드리겠습니다.</p>
      <a href="https://zrr.kr/BEsbko" target="_blank" rel="noopener" class="nav-link">무료 상담 신청하기 →</a>
    </div>
  </section>
</BaseLayout>

<!-- 매거진 스타일은 public/css/common.css 에 통합됨 -->
