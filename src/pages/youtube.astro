---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// displayOrder 오름차순 정렬
const videos = (await getCollection('youtube')).sort(
  (a, b) => a.data.displayOrder - b.data.displayOrder
);
---
<BaseLayout
  title="교회 인테리어 영상 SNS — 서울·부산·광주 컨빌디자인"
  description="서울·부산·광주 교회 인테리어 시공 영상과 SNS 콘텐츠. 예배당 리모델링 비포&애프터, 인터뷰, 디자인 노트를 영상으로 만나보세요."
  keywords="교회 인테리어 영상, 컨빌디자인 유튜브, 예배당 리모델링 비포애프터, 서울 부산 광주 교회 인테리어 영상, 교회 시공 영상"
  canonical="/youtube.html"
  ogTitle="교회 인테리어 영상 SNS — 서울·부산·광주 컨빌디자인"
  ogDescription="교회 인테리어 시공 영상과 SNS 콘텐츠 — 예배당 리모델링 비포&애프터, 인터뷰"
  ogImage="https://convill-homepage-ver2.vercel.app/images/main.png"
  activeNav="sns"
  pageJs="portfolio.js"
>
  <div>

    <section class="sns-title">
      <div class="container">
        <h1>SNS</h1>
        <hr class="sns-divider" />
      </div>
    </section>

    <section class="cat-head">
      <div class="container cat-row">
        <div class="cat-left">
          <h2 class="cat-name">Youtube</h2>
          <a href="https://www.youtube.com/" target="_blank" rel="noopener" class="cat-pill">
            유튜브 채널
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <nav class="cat-tabs">
          <!-- <a href="/magazine.html" class="nav-link">MAGAZINE</a> -->
          <span class="sep"></span>
          <span class="sns-active">YOUTUBE</span>
        </nav>
      </div>
    </section>

    <section class="yt-section">
      <div class="container">
        <div class="yt-grid" id="ytGrid">
          {videos.map(video => (
            <article class="yt-card" data-yt-item onclick={`window.open('${video.data.url}', '_blank')`}>
              <div class="yt-thumb">
                <div class="ph" style={`background-image:url('${video.data.thumbnail}')`}></div>
                <span class="yt-duration">{video.data.duration}</span>
              </div>
              <div class="yt-info">
                <h3>{video.data.title}</h3>
              </div>
            </article>
          ))}
        </div>
        <!-- YouTube 페이지네이션 -->
        <div class="pagination" id="ytPagination"></div>
      </div>
    </section>

    <section class="cta-strip">
      <div class="container">
        <span class="eye">— LET'S WORK TOGETHER</span>
        <h2>우리 교회도, <span class="ws">새로워질 수</span> 있습니다.</h2>
        <p>우리 교회에 가장 잘 어울리는 공간은 어떻게 시작해야 할까요?<br />혼자 고민하지 마세요. 저희가 도와드리겠습니다.</p>
        <a href="https://zrr.kr/BEsbko" target="_blank" rel="noopener" class="nav-link">무료 상담 신청하기 →</a>
      </div>
    </section>

  </div><!-- /page-sns-youtube -->
</BaseLayout>
