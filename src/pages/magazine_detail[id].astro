---
import { getCollection } from 'astro:content';
import MagazineDetailLayout from '../layouts/MagazineDetailLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('magazine');
  return entries.map(entry => ({
    params: { id: entry.data.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---
<MagazineDetailLayout entry={entry}>
  <Content />
</MagazineDetailLayout>
