---
interface Props {
  activeNav?: 'about' | 'portfolio' | 'paths' | 'branding' | 'process' | 'sns' | 'faq' | null;
}

const { activeNav = null } = Astro.props;

const isActive = (key: string) => activeNav === key ? 'nav-link nav-active' : 'nav-link';
---
<header class="site">
  <div class="container nav">
    <div class="brand" onclick="location.href='/index.html'">
      컨빌디자인
      <small>CHURCH INTERIOR STUDIO</small>
    </div>
    <ul>
      <li><a href="/index.html#about" class={isActive('about')}>소개</a></li>
      <li><a href="/portfolio_list.html" class={isActive('portfolio')}>포트폴리오</a></li>
      <li><a href="/index.html#paths" class={isActive('paths')}>서비스</a></li>
      <li><a href="/church-branding.html" class={isActive('branding')}>교회 브랜딩</a></li>
      <li><a href="/index.html#process" class={isActive('process')}>프로세스</a></li>
      <li><a href="/youtube.html" class={isActive('sns')}>SNS</a></li>
      <li><a href="/index.html#faq" class={isActive('faq')}>FAQ</a></li>
    </ul>
    <div class="nav-actions">
      <a href="https://zrr.kr/BEsbko" target="_blank" class="cta nav-link">무료 상담 신청</a>
      <button class="nav-mobile-toggle" onclick="openMobileMenu()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>
